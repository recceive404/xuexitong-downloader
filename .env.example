# =============================================================
# 学习通课件下载器 — 环境变量配置
# =============================================================
# 使用说明：
#   1. 复制本文件为 .env ：  cp .env.example .env
#   2. 填写下面的配置
#   3. .env 不会被提交到 Git（已在 .gitignore 中）
# =============================================================

# ---------- DeepSeek API（RAG 问答功能需要）----------
# 获取方式：https://platform.deepseek.com → 注册 → API Keys
# 如果只下载课件不使用 AI 问答，可以不填
ANTHROPIC_AUTH_TOKEN=你的DeepSeek_API_Key
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-pro[1m]

# ---------- HuggingFace 镜像（国内用户推荐）----------
# 设为 https://hf-mirror.com 可加速模型下载
# 国外用户可留空或删掉这行
HF_ENDPOINT=https://hf-mirror.com
